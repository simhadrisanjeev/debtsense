# =============================================================================
# DebtSense Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Application
APP_NAME=DebtSense
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_RELOAD=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=debtsense
POSTGRES_USER=debtsense_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider Configuration (provider-agnostic)
LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# Fallback LLM (optional)
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_API_KEY=your-fallback-key
LLM_FALLBACK_MODEL=claude-3-sonnet-20240229

# Email / Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@debtsense.com
SMTP_PASSWORD=change_me
FROM_EMAIL=noreply@debtsense.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Encryption (for PII at rest)
ENCRYPTION_KEY=change-this-32-byte-key-in-prod!

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
